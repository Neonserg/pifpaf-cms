# Public Supabase project reference — safe to commit, the publishable key
# only grants what Row Level Security policies allow.
NEXT_PUBLIC_SUPABASE_URL=https://uncpsomdrijhosgrdgwr.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_FUVUXFMMlPlKE8hDRLa5Bg_peXXv2p2

# Secret — never commit a real value here. Only used server-side once
# admin auth / privileged writes are wired up (Phase 1+).
SUPABASE_SERVICE_ROLE_KEY=

# Set to "on" to serve resized grid thumbnails via Supabase image
# transformations instead of full-resolution originals. Confirm transformations
# are available on the project's Supabase plan before enabling. Off = originals.
NEXT_PUBLIC_IMAGE_TRANSFORM=
