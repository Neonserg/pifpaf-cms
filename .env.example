# Neon Postgres — use the pooled connection string (hostname contains
# "-pooler"), required for serverless/Vercel connection limits.
DATABASE_URL=

# Signs the admin session cookie (HS256 JWT). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Keep secret; rotating it invalidates all logged-in sessions.
SESSION_SECRET=

# Cloudflare R2 (S3-compatible object storage for uploaded media).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for the bucket (r2.dev subdomain or a custom domain) —
# mediaPublicUrl() appends the storage path to this.
R2_PUBLIC_URL=
